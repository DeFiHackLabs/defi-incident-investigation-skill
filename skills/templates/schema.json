{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DeFi Hack Event",
  "description": "Strict schema for DeFi hack event records.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "date",
    "title",
    "protocol",
    "blockchain",
    "category",
    "ecosystem",
    "language",
    "estimatedLoss",
    "attackTime",
    "description",
    "transactions",
    "attackers",
    "victims",
    "rootCause",
    "attackVector",
    "lessons",
    "references",
    "metadata"
  ],
  "_metadata": {
    "fileNamingConvention": "YYYYMMDD-ProtocolName.json",
    "extensibleFields": {
      "description": "When no existing key matches, you MAY add a new key to these vocabularies.",
      "fields": [
        "languages",
        "ecosystems",
        "categories",
        "blockchains",
        "attackerRoles",
        "victimRoles",
        "transactionRoles"
      ]
    },
    "categories": [
      {
        "id": "access_control",
        "name": "Access Control Issue"
      },
      {
        "id": "bridge",
        "name": "Cross-chain Bridge Attack"
      },
      {
        "id": "business_logic",
        "name": "Business Logic Flaw"
      },
      {
        "id": "flashloan",
        "name": "Flashloan",
        "description": "Flash Loan Attack"
      },
      {
        "id": "forged_message",
        "name": "Forged Message Attack"
      },
      {
        "id": "governance_attack",
        "name": "Governance / DAO Attack"
      },
      {
        "id": "key_compromise",
        "name": "Private key Compromise"
      },
      {
        "id": "mev_front_running",
        "name": "MEV / Front-Running Attack"
      },
      {
        "id": "offchain_backend_exploit",
        "name": "Off-chain Backend Exploit"
      },
      {
        "id": "price_manipulation",
        "name": "Price Manipulation Attack"
      },
      {
        "id": "reentrancy",
        "name": "Reentrancy Attack"
      },
      {
        "id": "rug_pull",
        "name": "Rug Pull / Exit Scam"
      },
      {
        "id": "signature_abuse",
        "name": "Signature Abuse Attack"
      },
      {
        "id": "social_engineering",
        "name": "Social Engineering"
      },
      {
        "id": "mev_honeypot",
        "name": "MEV Honeypot Attack",
        "description": "Attacker deploys fake tokens, pools, and arbitrage opportunities to lure automated MEV bots into granting ERC-20 approvals or interacting with malicious contracts, then drains bot funds via transferFrom or callback exploitation."
      }

    ],
    "blockchains": [
      {
        "id": "arbitrum",
        "name": "Arbitrum"
      },
      {
        "id": "avalanche",
        "name": "Avalanche"
      },
      {
        "id": "base",
        "name": "Base"
      },
      {
        "id": "bitcoin",
        "name": "Bitcoin"
      },
      {
        "id": "bitcoin_cash",
        "name": "Bitcoin Cash"
      },
      {
        "id": "bsc",
        "name": "BSC"
      },
      {
        "id": "cosmos",
        "name": "Cosmos"
      },
      {
        "id": "dogecoin",
        "name": "Dogecoin"
      },
      {
        "id": "ethereum",
        "name": "Ethereum"
      },
      {
        "id": "fantom",
        "name": "Fantom"
      },
      {
        "id": "hyperevm",
        "name": "HyperEVM"
      },
      {
        "id": "litecoin",
